<odoo>
    <data>
        <!-- Grille de prix initiale -->
        <record id="grille_prix_2025" model="grille.prix">
            <field name="name">Grille tarifaire 2025</field>
            <field name="date_debut">2025-01-01</field>
        </record>

        <!-- Abonnement affine (ADR 0018) : une ligne par univers,
             base 3 kVA + coefficient par kVA. -->
        <record id="prix_abo_std" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_abonnement_standard"/>
            <field name="type_produit">abonnement</field>
            <field name="prix_base_3kva">150.00</field>
            <field name="coef_kva">12.00</field>
        </record>
        <record id="prix_abo_sol" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_abonnement_solidaire"/>
            <field name="type_produit">abonnement</field>
            <field name="prix_base_3kva">120.00</field>
            <field name="coef_kva">10.00</field>
        </record>

        <!-- Énergies standard (€/kWh) -->
        <record id="prix_energie_base" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_energie_base"/>
            <field name="type_produit">energie</field>
            <field name="prix_unitaire">0.1850</field>
        </record>
        <record id="prix_energie_hp" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_energie_hp"/>
            <field name="type_produit">energie</field>
            <field name="prix_unitaire">0.2010</field>
        </record>
        <record id="prix_energie_hc" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_energie_hc"/>
            <field name="type_produit">energie</field>
            <field name="prix_unitaire">0.1520</field>
        </record>

        <!-- Énergies solidaires (€/kWh) — produits isolés (ADR 0013) -->
        <record id="prix_energie_base_sol" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_energie_base_solidaire"/>
            <field name="type_produit">energie</field>
            <field name="prix_unitaire">0.1850</field>
        </record>
        <record id="prix_energie_hp_sol" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_energie_hp_solidaire"/>
            <field name="type_produit">energie</field>
            <field name="prix_unitaire">0.2010</field>
        </record>
        <record id="prix_energie_hc_sol" model="grille.prix.ligne">
            <field name="grille_id" ref="grille_prix_2025"/>
            <field name="product_id" ref="souscriptions_product_energie_hc_solidaire"/>
            <field name="type_produit">energie</field>
            <field name="prix_unitaire">0.1520</field>
        </record>
    </data>
</odoo>
