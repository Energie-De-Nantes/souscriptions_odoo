      "updated": 1760705975639,
      "link": null,
      "locked": false,
      "text": "On peut éditer librement les infos de\nla souscription ou la grille tarifaire",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On peut éditer librement les infos de la souscription ou la grille tarifaire",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "_EDUiRqFIJvsQqzbQlfF9",
      "type": "text",
      "x": 957.1463618243403,
      "y": 1327.3590769528275,
      "width": 371.8156553212936,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
