<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_groups_privilege_souscriptions" model="res.groups.privilege">
        <field name="name">Souscriptions</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_souscriptions_user" model="res.groups">
        <field name="name">Utilisateur</field>
        <field name="privilege_id" ref="res_groups_privilege_souscriptions"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_souscriptions_manager" model="res.groups">
        <field name="name">Gestionnaire</field>
        <field name="privilege_id" ref="res_groups_privilege_souscriptions"/>
        <field name="implied_ids" eval="[(4, ref('group_souscriptions_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
