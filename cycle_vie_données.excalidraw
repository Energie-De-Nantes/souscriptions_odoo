    {
      "id": "6Ef2uax0twybk60fPDnHy",
      "type": "text",
      "x": 1560.040956948265,
      "y": 659.6690430645076,
      "width": 108.36042785644531,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3p",
