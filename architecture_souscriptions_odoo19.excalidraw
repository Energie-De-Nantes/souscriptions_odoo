    {
      "type": "text",
      "id": "principe_title",
      "x": 1100, "y": 665, "width": 400, "height": 24,
      "text": "Principe directeur", "originalText": "Principe directeur",
      "fontSize": 19, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#1e40af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 700001, "version": 1, "versionNonce": 700002, "isDeleted": false,
