    {
      "id": "EZv2elbnJ44LH2j4bje-E",
      "type": "text",
      "x": 3285.3390915486216,
      "y": -668.0206832839019,
      "width": 316.8294270833327,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5T",
      "roundness": null,
      "seed": 118290742,
      "version": 379,
      "versionNonce": 800950506,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1762255632528,
      "link": null,
      "locked": false,
      "text": "Etat courant de la\nsouscription, hp/hc ou\nbase, tarif solidaire,\nPuissance souscrite\netc...\n\nToute modif sera\nautomatiquement prise\nen compte pour la\nprochaine factu !",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Etat courant de la souscription, hp/hc ou base, tarif solidaire, Puissance souscrite etc...\n\nToute modif sera automatiquement prise en compte pour la prochaine factu !",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "kJSg63fBySHg2KidwRCuV",
      "type": "text",
      "x": 4808.675421659687,
      "y": 460.6148961431812,
      "width": 799.9963378906253,
      "height": 245,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5U",
      "roundness": null,
      "seed": 1350247146,
      "version": 479,
      "versionNonce": 1001425258,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1762257209612,
      "link": null,
      "locked": false,
      "text": "Il faut au max éviter de modifier ce modèle Odoo (mis à\npar le rapport aka pdf). Plus on modifie les modèles Odoo\nexistants, plus on risque que galérer lors d'une MAJ Odoo.\n\nOn pourrait toutefois ajouter des trucs légers ou utiliser\ndes mécaniques/champs existants pour pouvoir générer\nfacilement les paiements par lots. ",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Il faut au max éviter de modifier ce modèle Odoo (mis à par le rapport aka pdf). Plus on modifie les modèles Odoo existants, plus on risque que galérer lors d'une MAJ Odoo.\n\nOn pourrait toutefois ajouter des trucs légers ou utiliser des mécaniques/champs existants pour pouvoir générer facilement les paiements par lots. ",
      "autoResize": false,
      "lineHeight": 1.25
    }
